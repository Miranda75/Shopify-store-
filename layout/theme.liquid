<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if template == 'index' %}Le Choix de Miranda | Boutique en ligne{% else %}{{ page_title }}{% if page_title != shop.name %} · {{ shop.name }}{% endif %}{% endif %}</title>
  <meta name="description" content="{% if page_description != blank %}{{ page_description | escape }}{% elsif shop.description != blank %}{{ shop.description | escape }}{% else %}Découvrez une sélection raffinée de mode, maison, beauté, sport et accessoires chez Le Choix de Miranda.{% endif %}">
  <meta name="robots" content="index, follow">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  <meta property="og:description" content="{% if page_description != blank %}{{ page_description | escape }}{% elsif shop.description != blank %}{{ shop.description | escape }}{% endif %}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  {% if page_image %}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
    <meta name="twitter:image" content="{{ page_image | image_url: width: 1200 }}">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | default: shop.name }}">
  <meta name="twitter:description" content="{% if page_description != blank %}{{ page_description | escape }}{% elsif shop.description != blank %}{{ shop.description | escape }}{% endif %}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {% if canonical_url != blank %}
    <link rel="canonical" href="{{ canonical_url }}">
  {% endif %}

  {{ content_for_header }}
</head>

<body class="bg-ivory text-charcoal font-sans">
  <a href="#main" class="sr-only">Aller au contenu principal</a>

  {% section 'header' %}

  <main id="main" class="flex-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
