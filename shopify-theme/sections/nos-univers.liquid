
 {% assign featured_menu = linklists['main-menu'] %}
{% if featured_menu != blank and featured_menu.links.size > 0 %}
      <div class="miranda-category-strip" aria-label="Univers boutique">
        {% for link in featured_menu.links limit: 6 %}
          <a href="{{ link.url }}" class="miranda-category-card">
            <span class="miranda-category-card__label">{{ link.title }}</span>
            <span class="miranda-category-card__cta">Explorer ↗</span>
          </a>
        {% endfor %}
      </div>
    {% endif %}

{% schema %}
{
  "name": "Nos Univers",
  "settings": [],
  "presets": [
    {
      "name": "Nos Univers"
    }
  ]
}
{% endschema %}


{{ 'nos-univers.css' | asset_url | stylesheet_tag }}

<style>
  .nos-univers {
    padding: clamp(2rem, 4vw, 4rem) 0;
  }

  .nos-univers__container {
    width: min(1200px, 100% - 2rem);
    margin-inline: auto;
  }

  .nos-univers__heading {
    margin: 0 0 clamp(1rem, 2.2vw, 1.75rem);
    text-align: center;
  }

  .nos-univers__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.875rem, 1.8vw, 1.25rem);
  }

  @media (min-width: 750px) {
    .nos-univers__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 990px) {
    .nos-univers__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .nos-univers__card {
    position: relative;
    display: block;
    border-radius: 24px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: rgba(0, 0, 0, 0.03);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(0) scale(1);
    transition:
      transform 320ms cubic-bezier(.22, .61, .36, 1),
      box-shadow 320ms cubic-bezier(.22, .61, .36, 1);
    will-change: transform, box-shadow;
  }

  .nos-univers__media {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
  }

  .nos-univers__image,
  .nos-univers__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .nos-univers__image {
    object-fit: cover;
    object-position: center;
    transform: scale(1.001);
    transition:
      transform 500ms cubic-bezier(.22, .61, .36, 1),
      filter 320ms ease;
    will-change: transform, filter;
  }

  .nos-univers__placeholder {
    background:
      linear-gradient(135deg, rgba(0, 0, 0, 0.06), rgba(0, 0, 0, 0.02));
  }

  .nos-univers__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.45) 8%,
      rgba(0, 0, 0, 0.14) 55%,
      rgba(0, 0, 0, 0.03) 100%
    );
    pointer-events: none;
    transition: opacity 260ms ease;
  }

  .nos-univers__title {
    position: absolute;
    inset-inline-start: 1rem;
    inset-block-end: 1rem;
    z-index: 1;
    margin: 0;
    color: #fff;
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  @media (hover: hover) and (pointer: fine) {
    .nos-univers__card:hover,
    .nos-univers__card:focus-visible {
      transform: translateY(-4px) scale(1.02);
      box-shadow:
        0 2px 6px rgba(0, 0, 0, 0.08),
        0 14px 34px rgba(0, 0, 0, 0.14);
    }

    .nos-univers__card:hover .nos-univers__image,
    .nos-univers__card:focus-visible .nos-univers__image {
      transform: scale(1.06);
      filter: saturate(1.04) contrast(1.02);
    }
  }

  .nos-univers__card:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.95);
    outline-offset: -4px;
  }

  .nos-univers__empty {
    margin: 0;
    text-align: center;
    opacity: 0.7;
  }
</style>

<section class="nos-univers section-{{ section.id }}" id="NosUnivers-{{ section.id }}">
  <div class="nos-univers__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="nos-univers__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="nos-univers__grid">
        {% for block in section.blocks %}
          {%- assign selected_collection = block.settings.collection -%}
          {%- assign card_url = '#' -%}
          {%- if selected_collection != blank -%}
            {%- assign card_url = selected_collection.url -%}
          {%- endif -%}

          <a
            class="nos-univers__card"
            href="{{ card_url }}"
            {% if selected_collection == blank %}aria-disabled="true"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="nos-univers__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1600
                  | image_tag:
                    class: 'nos-univers__image',
                    alt: block.settings.title,
                    loading: 'lazy',
                    widths: '400, 600, 800, 1000, 1200, 1400, 1600',
                    sizes: '(min-width: 990px) calc((100vw - 64px) / 3), (min-width: 750px) calc((100vw - 48px) / 2), calc(100vw - 32px)'
                }}
              {%- else -%}
                <div class="nos-univers__placeholder" aria-hidden="true"></div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <p class="nos-univers__title">{{ block.settings.title }}</p>
              {%- elsif selected_collection != blank -%}
                <p class="nos-univers__title">{{ selected_collection.title }}</p>
              {%- endif -%}
            </div>
          </a>
        {% endfor %}
      </div>
    {%- else -%}
      <p class="nos-univers__empty">Add category cards to this section.</p>
    {%- endif -%}
  </div>
</section>

<script src="{{ 'nos-univers.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Nos Univers",
  "tag": "section",
  "class": "section section-nos-univers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nos Univers"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "🏠 Maison"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Nos Univers",
      "blocks": [
        { "type": "category_card", "settings": { "title": "🏠 Maison" } },
        { "type": "category_card", "settings": { "title": "💄 Beauté" } },
        { "type": "category_card", "settings": { "title": "⌚ Accessoires" } },
        { "type": "category_card", "settings": { "title": "🏃 Sport" } },
        { "type": "category_card", "settings": { "title": "💻 Électronique" } },
        { "type": "category_card", "settings": { "title": "🎁 Nouveautés" } }
      ]
    }
  ]
}
{% endschema %}
/* ============================================
   STYLES LUXUEUX POUR NOS UNIVERS (Option 3)
   ============================================ */

/* Cartes avec dégradés luxueux */
.nos-univers__card:nth-child(1) .nos-univers__media {
    background: linear-gradient(135deg, #D4A574 0%, #8B6B4A 100%);
}

.nos-univers__card:nth-child(2) .nos-univers__media {
    background: linear-gradient(135deg, #F5A0B0 0%, #C76B8A 100%);
}

.nos-univers__card:nth-child(3) .nos-univers__media {
    background: linear-gradient(135deg, #C9A96E 0%, #8B7A4A 100%);
}

.nos-univers__card:nth-child(4) .nos-univers__media {
    background: linear-gradient(135deg, #6BB5C9 0%, #3A7A8A 100%);
}

.nos-univers__card:nth-child(5) .nos-univers__media {
    background: linear-gradient(135deg, #7A8BB5 0%, #4A5A7A 100%);
}

.nos-univers__card:nth-child(6) .nos-univers__media {
    background: linear-gradient(135deg, #C9A96E 0%, #D4A574 100%);
}

/* Icônes plus grandes et titre stylé */
.nos-univers__title {
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: 'Georgia', 'Times New Roman', serif;
}

/* Ligne dorée sous le titre */
.nos-univers__title::before {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: #C9A96E;
    margin-bottom: 0.5rem;
    border-radius: 2px;
}

/* Effet de brillance sur les cartes */
.nos-univers__media {
    position: relative;
    overflow: hidden;
}

.nos-univers__media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.1) 0%,
        transparent 50%,
        rgba(255, 255, 255, 0.05) 100%
    );
    pointer-events: none;
    z-index: 1;
}

/* Amélioration du hover */
.nos-univers__card {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 
        0 4px 6px rgba(0,0,0,0.02),
        0 12px 40px rgba(0,0,0,0.08);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

.nos-univers__card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 
        0 8px 12px rgba(0,0,0,0.04),
        0 24px 60px rgba(0,0,0,0.15);
}

/* Overlay plus foncé pour meilleure lisibilité */
.nos-univers__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
        to top,
        rgba(0,0,0,0.7) 0%,
        rgba(0,0,0,0.1) 50%,
        transparent 100%
    );
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.nos-univers__card:hover .nos-univers__media::after {
    opacity: 0.8;
}

/* Style spécial pour la carte "Nouveautés" */
.nos-univers__card:nth-child(6) .nos-univers__title::after {
    content: '✨';
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.8em;
}
