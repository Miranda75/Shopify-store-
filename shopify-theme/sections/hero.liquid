<section class="hero-section">

  {% if section.settings.image %}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.title }}"
      class="hero-image">
  {% endif %}

  <div class="hero-overlay"></div>

  <div class="hero-content">

    {% if section.settings.title %}
      <h1>{{ section.settings.title }}</h1>
    {% endif %}

    {% if section.settings.subtitle %}
      <p>{{ section.settings.subtitle }}</p>
    {% endif %}

    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link }}" class="hero-button">
        {{ section.settings.cta_text }}
      </a>
    {% endif %}

  </div>

</section>

<style>
.hero-section{
  position:relative;
  width:100%;
  height:85vh;
  min-height:600px;
  overflow:hidden;
}

.hero-image{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}

.hero-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.35);
}

.hero-content{
  position:relative;
  z-index:2;
  height:100%;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  padding:20px;
  color:#fff;
}

.hero-content h1{
  font-size:60px;
  margin-bottom:20px;
  font-weight:300;
  line-height:1.1;
}

.hero-content p{
  font-size:22px;
  margin-bottom:35px;
  max-width:700px;
}

.hero-button{
  display:inline-block;
  background:#111;
  color:#fff;
  text-decoration:none;
  padding:16px 40px;
  border:2px solid #fff;
  text-transform:uppercase;
  letter-spacing:2px;
  transition:.3s;
}

.hero-button:hover{
  background:#fff;
  color:#111;
}

@media(max-width:768px){

.hero-section{
height:70vh;
min-height:500px;
}

.hero-content h1{
font-size:38px;
}

.hero-content p{
font-size:18px;
}

}
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "L'Élégance Redéfinie"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Découvrez notre nouvelle collection"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Découvrir"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}


