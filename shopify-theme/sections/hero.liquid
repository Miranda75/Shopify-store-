<section class="relative w-full min-h-[80vh] md:min-h-screen flex items-center justify-center overflow-hidden">

  {% if section.settings.image %}
    {{ section.settings.image | image_url: width: 2200 | image_tag:
      class: "absolute inset-0 w-full h-full object-cover",
      loading: "eager"
    }}
  {% endif %}

  <div class="absolute inset-0 bg-black/40"></div>

  <div class="relative z-10 max-w-3xl text-center px-6">

    {% if section.settings.title %}
      <h1 class="text-5xl md:text-7xl font-serif font-light leading-tight text-white mb-6">
        {{ section.settings.title }}
      </h1>
    {% endif %}

    {% if section.settings.subtitle %}
      <p class="text-lg md:text-2xl text-white/90 mb-10">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}

    {% if section.settings.cta_text and section.settings.cta_link %}
      <a href="{{ section.settings.cta_link }}"
         class="inline-block px-10 py-4 border-2 border-white text-white uppercase tracking-[4px] hover:bg-white hover:text-black transition duration-300">
        {{ section.settings.cta_text }}
      </a>
    {% endif %}

  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "L'Élégance Redéfinie"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Découvrez notre nouvelle collection"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Découvrir La Collection"
    },
{
  "type": "url",
  "id": "cta_link",
  "label": "Lien du bouton"
}
    
    
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
