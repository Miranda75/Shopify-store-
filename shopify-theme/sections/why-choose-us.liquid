<section class="miranda-club-section">
  <div class="miranda-shell miranda-club-section__inner">
    <div class="miranda-club-section__content">
      {% if section.settings.eyebrow != blank %}
        <p class="miranda-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2>{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="miranda-club-section__text">{{ section.settings.text }}</p>
      {% endif %}

      <div class="miranda-club-section__highlights">
        <span>Avant-premières exclusives</span>
        <span>Retours offerts sous 14 jours</span>
        <span>Livraison suivie partout en France</span>
      </div>

      {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
        <a href="{{ section.settings.cta_link }}" class="miranda-button miranda-button--secondary">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>

    <div class="miranda-club-section__card">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'miranda-club-section__image', loading: 'lazy', alt: section.settings.title | escape }}
      {% else %}
        <div class="miranda-club-section__card-copy">
          <p class="miranda-eyebrow">Le Cercle</p>
          <h3>Recevez en avant-première nos sélections, nos nouveautés et nos offres privées.</h3>
          <p>Une sélection raffinée, pensée pour rester élégante sur mobile comme sur desktop.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Club Le Choix",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "✨ Club Le Choix"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Recevez en avant-première nos nouveautés"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Inscrivez-vous pour découvrir nos nouveaux arrivages, nos éditos et nos offres privées avant tout le monde."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Rejoindre le club"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image d'accompagnement"
    }
  ],
  "presets": [
    {
      "name": "Club Le Choix"
    }
  ]
}
{% endschema %}
