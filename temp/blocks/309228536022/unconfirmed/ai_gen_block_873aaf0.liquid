{% doc %}
  @prompt
    Add a "Nos Univers" block inside the existing Header section. It should display a row of brand universe categories (e.g. Prêt-à-porter, Accessoires, Maison) with customizable images, titles, and links for each universe. The design should match a luxury fashion brand aesthetic with clean typography, gold accents, and minimal elegant styling. Each universe item should be configurable with an image, a label/title, and a URL link. The block should appear as a sub-navigation or showcase strip within or just below the header.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-nos-univers-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
    border-top: 1px solid {{ block.settings.border_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-nos-univers-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-nos-univers-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-nos-univers-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    align-items: start;
  }

  .ai-nos-univers-item-{{ ai_gen_id }} {
    position: relative;
    text-align: center;
    text-decoration: none;
    display: block;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-nos-univers-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    opacity: 0.9;
  }

  .ai-nos-univers-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.label_spacing }}px;
    background-color: #f4f4f4;
  }

  .ai-nos-univers-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-nos-univers-item-{{ ai_gen_id }}:hover .ai-nos-univers-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-nos-univers-image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-nos-univers-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%);
    pointer-events: none;
  }

  .ai-nos-univers-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    text-transform: {{ block.settings.label_transform }};
    margin: 0;
    transition: color 0.3s ease;
  }

  .ai-nos-univers-item-{{ ai_gen_id }}:hover .ai-nos-univers-label-{{ ai_gen_id }} {
    color: {{ block.settings.label_hover_color }};
  }

  .ai-nos-univers-accent-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.accent_width }}px;
    height: {{ block.settings.accent_height }}px;
    background-color: {{ block.settings.accent_color }};
    margin: {{ block.settings.accent_spacing }}px auto 0;
    transition: width 0.3s ease;
  }

  .ai-nos-univers-item-{{ ai_gen_id }}:hover .ai-nos-univers-accent-{{ ai_gen_id }} {
    width: {{ block.settings.accent_hover_width }}px;
  }

  .ai-nos-univers-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-nos-univers-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-nos-univers-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-nos-univers-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-nos-univers-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.9);
    }

    .ai-nos-univers-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding | times: 0.7 }}px 0;
    }
  }
{% endstyle %}

<nos-univers-{{ ai_gen_id }} class="ai-nos-univers-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-nos-univers-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-nos-univers-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    {% liquid
      assign has_content = false
      for i in (1..6)
        assign universe_enabled_key = 'universe_' | append: i | append: '_enabled'
        if block.settings[universe_enabled_key]
          assign has_content = true
          break
        endif
      endfor
    %}

    {% if has_content %}
      <div class="ai-nos-univers-grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign universe_enabled_key = 'universe_' | append: i | append: '_enabled'
            assign universe_image_key = 'universe_' | append: i | append: '_image'
            assign universe_label_key = 'universe_' | append: i | append: '_label'
            assign universe_url_key = 'universe_' | append: i | append: '_url'

            assign universe_enabled = block.settings[universe_enabled_key]
            assign universe_image = block.settings[universe_image_key]
            assign universe_label = block.settings[universe_label_key]
            assign universe_url = block.settings[universe_url_key]
          %}

          {% if universe_enabled %}
            <a
              href="{% if universe_url != blank %}{{ universe_url }}{% else %}#{% endif %}"
              class="ai-nos-univers-item-{{ ai_gen_id }}"
              {% if universe_label != blank %}aria-label="{{ universe_label }}"{% endif %}
            >
              <div class="ai-nos-univers-image-wrapper-{{ ai_gen_id }}">
                {% if universe_image %}
                  <img
                    src="{{ universe_image | image_url: width: 600 }}"
                    alt="{{ universe_label | escape }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | divided_by: block.settings.image_aspect_ratio | round }}"
                    class="ai-nos-univers-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                {% endif %}
                {% if block.settings.show_overlay %}
                  <div class="ai-nos-univers-overlay-{{ ai_gen_id }}"></div>
                {% endif %}
              </div>

              {% if universe_label != blank %}
                <p class="ai-nos-univers-label-{{ ai_gen_id }}">{{ universe_label }}</p>
                {% if block.settings.show_accent %}
                  <span class="ai-nos-univers-accent-{{ ai_gen_id }}"></span>
                {% endif %}
              {% endif %}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-nos-univers-empty-state-{{ ai_gen_id }}">
        <p>Enable and configure your brand universes in the block settings</p>
      </div>
    {% endif %}
  </div>
</nos-univers-{{ ai_gen_id }}>

<script>
  (function() {
    class NosUnivers{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-nos-univers-item-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.items.forEach((item) => {
          item.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              item.click();
            }
          });
        });
      }
    }

    customElements.define('nos-univers-{{ ai_gen_id }}', NosUnivers{{ ai_gen_id }});
  })();
</script>

