<div class="announcement-bar bg-charcoal text-ivory text-center py-2 text-xs tracking-widest uppercase">
  <p>{{ section.settings.announcement_text }}</p>
</div>

<header class="sticky top-0 z-50 bg-ivory border-b border-border/50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-4 flex items-center justify-between gap-4">
    
    <!-- Mobile menu toggle -->
    <button class="md:hidden p-2 -ml-2 hover:bg-warm-beige transition-colors" type="button" aria-label="Menu" data-mobile-menu-toggle>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Logo -->
    <a href="{{ shop.url }}" class="flex-shrink-0 font-serif text-lg md:text-xl font-light tracking-wide text-charcoal hover:text-gold transition-colors" title="{{ shop.name }}">
      <span class="hidden sm:inline">{{ shop.name }}</span>
      <span class="sm:hidden">Miranda</span>
    </a>

    <!-- Search bar - Desktop -->
    <div class="hidden md:flex flex-1 max-w-md mx-auto">
      <form action="{{ shop.url }}/search" method="get" class="w-full">
        <div class="relative">
          <input 
            type="text" 
            name="q" 
            placeholder="Rechercher..." 
            class="w-full border-b border-charcoal/20 focus:border-gold focus:outline-none py-2 px-0 text-sm bg-transparent transition-colors" 
            autocomplete="off">
          <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2 p-2 hover:text-gold transition-colors" aria-label="Rechercher">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
        </div>
      </form>
    </div>

    <!-- Right icons -->
    <div class="flex items-center gap-1 md:gap-4 flex-shrink-0">
      
      <!-- Search icon - Mobile -->
      <button class="md:hidden p-2 hover:text-gold transition-colors" type="button" aria-label="Rechercher" data-search-toggle>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </button>

      <!-- Account -->
      <a href="{{ shop.url }}/account" class="p-2 hover:text-gold transition-colors" title="Mon compte" aria-label="Mon compte">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
        </svg>
      </a>

      <!-- Wishlist -->
      <a href="{{ shop.url }}/pages/wishlist" class="p-2 hover:text-gold transition-colors relative" title="Mes favoris" aria-label="Mes favoris" data-wishlist-link>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
        <span class="wishlist-count hidden absolute -top-1 -right-1 text-[10px] bg-gold text-ivory w-4 h-4 flex items-center justify-center rounded-full text-xs font-medium" data-wishlist-count>0</span>
      </a>

      <!-- Cart -->
      <a href="{{ shop.url }}/cart" class="p-2 hover:text-gold transition-colors relative" title="Panier" aria-label="Panier" data-cart-link>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
        </svg>
        <span class="cart-count absolute -top-1 -right-1 text-[10px] bg-charcoal text-ivory w-4 h-4 flex items-center justify-center rounded-full text-xs font-medium" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  <!-- Mobile search bar -->
  <div class="hidden md:hidden border-t border-border/50 px-4 py-3" data-mobile-search>
    <form action="{{ shop.url }}/search" method="get">
      <div class="relative">
        <input 
          type="text" 
          name="q" 
          placeholder="Rechercher un produit..." 
          class="w-full border-b border-charcoal/20 focus:border-gold focus:outline-none py-2 px-0 text-sm bg-transparent transition-colors" 
          autocomplete="off">
        <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2 p-2 hover:text-gold transition-colors" aria-label="Rechercher">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <!-- Mobile navigation menu -->
  <nav class="hidden md:hidden border-t border-border/50 bg-ivory" data-mobile-menu>
    <div class="px-4 py-3 space-y-3">
      {% for link in linklists.main-menu.links %}
        <a href="{{ link.url }}" class="block text-sm uppercase tracking-widest text-charcoal hover:text-gold transition-colors">
          {{ link.title }}
        </a>
      {% endfor %}
      <div class="border-t border-border/50 pt-3 mt-3">
        <a href="{{ shop.url }}/pages/contact" class="block text-xs uppercase tracking-widest text-charcoal hover:text-gold transition-colors mb-2">Contact</a>
        <a href="{{ shop.url }}/policies/privacy-policy" class="block text-xs uppercase tracking-widest text-charcoal hover:text-gold transition-colors">Confidentialité</a>
      </div>
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Texte annonce",
      "default": "🚚 Livraison gratuite dès 50€"
    }
  ]
}
{% endschema %}

<style>
  .announcement-bar {
    background-color: var(--color-charcoal, #1F1F1F);
    color: var(--color-ivory, #F9F8F6);
  }

  header {
    background-color: var(--color-ivory, #F9F8F6);
    border-color: var(--color-border, #E5E0D8);
  }

  header a:hover,
  header button:hover {
    color: var(--color-gold, #C9A227);
  }

  input::placeholder {
    color: rgba(31, 31, 31, 0.4);
  }

  input:focus {
    border-color: var(--color-gold, #C9A227);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Mobile menu toggle
    const mobileMenuToggle = document.querySelector('[data-mobile-menu-toggle]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    
    if (mobileMenuToggle && mobileMenu) {
      mobileMenuToggle.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
    }

    // Mobile search toggle
    const searchToggle = document.querySelector('[data-search-toggle]');
    const mobileSearch = document.querySelector('[data-mobile-search]');
    
    if (searchToggle && mobileSearch) {
      searchToggle.addEventListener('click', function() {
        mobileSearch.classList.toggle('hidden');
      });
    }

    // Update wishlist count
    function updateWishlistCount() {
      const wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
      const countElement = document.querySelector('[data-wishlist-count]');
      if (countElement) {
        if (wishlist.length > 0) {
          countElement.textContent = wishlist.length;
          countElement.classList.remove('hidden');
        } else {
          countElement.classList.add('hidden');
        }
      }
    }
    
    updateWishlistCount();
    window.addEventListener('storage', updateWishlistCount);
  });
</script>
