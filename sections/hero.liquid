{% liquid
  assign featured_menu = linklists['main-menu']
%}

<section class="miranda-home-hero">
  <div class="miranda-shell">
    <div class="miranda-home-hero__frame">
      {% if section.settings.image %}
{{ section.settings.image
  | image_url: width: 1400
  | image_tag:
    widths: '375,550,750,1100,1400',
    sizes: '(max-width: 749px) 100vw, 1400px',
    loading: 'eager',
    fetchpriority: 'high',
    class: 'miranda-home-hero__image',
    alt: section.settings.image_alt
}}

      

        
      {% else %}
        <div class="miranda-home-hero__placeholder">
          <p>Ajoutez votre visuel homepage dans les paramètres de la section Hero.</p>
        </div>
      {% endif %}
    </div>

    {% if section.settings.subtitle != blank or section.settings.title != blank or section.settings.cta_text != blank %}
      <div class="miranda-home-hero__content">
        {% if section.settings.subtitle != blank %}
          <p class="miranda-eyebrow">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.title != blank %}
          <h1>{{ section.settings.title }}</h1>
        {% endif %}
        {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
          <a href="{{ section.settings.cta_link }}" class="miranda-button miranda-button--primary">{{ section.settings.cta_text }}</a>
        {% endif %}
      </div>
    {% endif %}

    {% if featured_menu != blank and featured_menu.links.size > 0 %}
      <div class="miranda-category-strip" aria-label="Univers boutique">
        {% for link in featured_menu.links limit: 6 %}
          <a href="{{ link.url }}" class="miranda-category-card">
            <span class="miranda-category-card__label">{{ link.title }}</span>
            <span class="miranda-category-card__cta">Explorer ↗</span>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image principale"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif image",
      "default": "Visuel éditorial Le Choix de MN"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sur-titre",
      "default": "Sélectionné pour vous"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Le choix qui vous rassemble"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Découvrir la collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
