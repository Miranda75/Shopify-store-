<section class="relative w-full min-h-96 md:min-h-screen flex items-center justify-center bg-warm-beige overflow-hidden">
  {% if section.settings.image %}
{{ section.settings.image | image_url: width: 2000 | image_tag:
  class: "absolute inset-0 w-full h-full object-cover",
  loading: "lazy"
}} alt="{{ section.settings.title }}" class="absolute inset-0 w-full h-full object-cover">
  {% endif %}
  
  <div class="relative z-10 text-center max-w-2xl px-6">
    {% if section.settings.title %}
<h1 class="text-4xl md:text-6xl font-serif tracking-tight leading-tight mb-6" style="color:#ffffff; text-shadow:2px 2px 8px rgba(0,0,0,.6);">
      {{ section.settings.title }}</h1>
    {% endif %}
    
    {% if section.settings.subtitle %}
<p class="text-lg md:text-xl mb-8" style="color:#ffffff; text-shadow:2px 2px 8px rgba(0,0,0,.6);">
      {{ section.settings.subtitle }}</p>
    {% endif %}
    
    {% if section.settings.cta_text and section.settings.cta_link %}
      

<a href="{{ section.settings.cta_link }}"
   class="inline-block px-8 py-4 text-sm uppercase tracking-widest"
   style="background:#111111;color:#ffffff;border:2px solid #ffffff;">
  {{ section.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "L'Élégance Redéfinie"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Découvrez notre nouvelle collection"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Découvrir"
    },
{
  "type": "url",
  "id": "cta_link",
  "label": "Lien du bouton"
}
    
    
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
