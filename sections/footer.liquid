<footer class="miranda-footer">
  <div class="miranda-shell">
    <div class="miranda-footer__grid">
      <div class="miranda-footer__brand">
        <a href="{{ routes.root_url }}" class="miranda-brand miranda-brand--light" aria-label="{{ shop.name }}">
          <span class="miranda-brand__mark">MN</span>
          <span class="miranda-brand__text">
            <span class="miranda-brand__name">Le Choix de Miranda</span>
            <span class="miranda-brand__tag">Maison · Paris</span>
          </span>
        </a>
        <p>{{ section.settings.footer_brand_description }}</p>
      </div>

      <div>
        <h3>Boutique</h3>
        <ul>
          {% for link in linklists.main-menu.links limit: 6 %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <h3>Informations</h3>
        <ul>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/policies/privacy-policy">Politique de confidentialité</a></li>
          <li><a href="/policies/terms-of-service">Conditions générales</a></li>
          <li><a href="/policies/refund-policy">Politique de retour</a></li>
        </ul>
      </div>

      <div>
        <h3>Newsletter</h3>
        <p>{{ section.settings.newsletter_text }}</p>
        {% form 'customer', class: 'miranda-footer__newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="Votre adresse e-mail" aria-label="Votre adresse e-mail" required>
          <button type="submit">S'inscrire</button>
          {% if form.posted_successfully? %}
            <p class="miranda-form-message">Merci, votre inscription est bien prise en compte.</p>
          {% endif %}
          {% if form.errors %}
            <p class="miranda-form-message miranda-form-message--error">{{ form.errors | default_errors }}</p>
          {% endif %}
        {% endform %}

        <div class="miranda-footer__badges" aria-label="Paiement sécurisé">
          <span>Visa</span>
          <span>Mastercard</span>
          <span>PayPal</span>
          <span>SSL</span>
        </div>
      </div>
    </div>

    <div class="miranda-footer__bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ section.settings.footer_copyright }}</p>
      <p>Fait avec soin à Paris</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_brand_description",
      "label": "Description de la marque",
      "default": "Une maison française dédiée aux objets d'exception : maison, beauté, accessoires, sport et électronique."
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Texte newsletter",
      "default": "Nouveautés, éditos et invitations privées directement dans votre boîte mail."
    },
    {
      "type": "text",
      "id": "footer_copyright",
      "label": "Copyright",
      "default": "Le Choix de MN · Tous droits réservés"
    }
  ]
}
{% endschema %}
